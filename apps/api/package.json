{
  "name": "api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "tsup src/app.ts src/queues/ocr.worker.ts --format cjs --dts",
    "start": "node dist/app.js",
    "worker": "node dist/queues/ocr.worker.js",
    "worker:tsx": "tsx src/queues/ocr.worker.ts",
    "worker:dev": "tsx watch src/queues/ocr.worker.ts",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "force-delete": "tsx scripts/force-delete-user.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@fastify/cors": "^10.0.2",
    "@fastify/helmet": "^13.0.1",
    "@fastify/jwt": "^9.1.0",
    "@fastify/multipart": "^9.0.1",
    "@supabase/supabase-js": "^2.49.4",
    "bullmq": "^5.49.0",
    "dotenv": "^16.5.0",
    "fastify": "^5.3.2",
    "fastify-plugin": "^5.1.0",
    "ioredis": "^5.6.1",
    "papaparse": "^5.5.3",
    "pdf-parse": "^1.1.1",
    "ws": "^8.21.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.31",
    "@types/papaparse": "^5.3.17",
    "@types/ws": "^8.18.1",
    "tsup": "^8.5.0",
    "tsx": "^4.19.4",
    "typescript": "^5.9.3"
  }
}